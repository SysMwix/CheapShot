# =============================================================================
# CheapShot — Fully Self-Hosted Configuration
# No cloud API keys needed! Everything runs locally.
# =============================================================================

# --- Ollama (Local AI) ---
# Runs locally or on a network machine for price extraction + analysis
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENABLED=true

# For a more powerful machine (OptiPlex, desktop):
# OLLAMA_MODEL=qwen2.5:7b

# For Pi cluster (via load balancer):
# OLLAMA_URL=http://10.50.0.10:11435

# --- SearXNG (Self-hosted web search) ---
# Replaces Claude's web search — fully local
SEARXNG_URL=http://localhost:8080

# --- Optional ---
# Override database path (defaults to ./cheapshot.db)
# DB_PATH=/app/data/cheapshot.db
